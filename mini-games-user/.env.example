NODE_ENV=development
PORT=4000
APP_NAME=mini-games-user
CORS_ORIGIN=http://localhost:3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mini_games_user
REDIS_URL=redis://localhost:6379
SESSION_TTL_SECONDS=604800
SESSION_COOKIE_NAME=mg_session
SESSION_COOKIE_SECURE=false
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_LOGIN_MAX_AGE_SECONDS=300
ADMIN_DEFAULT_USERNAME=superadmin
ADMIN_DEFAULT_PASSWORD=change_me
DEFAULT_CURRENCY=ETB
LOG_LEVEL=info
